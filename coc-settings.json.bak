{
  "coc.preferences.formatOnSave": false,
  "coc.preferences.formatOnType": true,
  "suggest.noselect": true,
  "codeLens.enable": true,
  "diagnostic": {
    "virtualText": true,
    "refreshOnInsertMode": true,
  },
  "git.floatConfig": {
    "border": true
  },
  "diagnostic.floatConfig": {
    "border": true
  },
  "signature.floatConfig": {
    "border": true
  },
  "hover.floatConfig": {
    "border": true
  },
  "sumneko-lua.enableNvimLuaDev": true,
  "Lua.format.defaultConfig": {
    "indent_style": "space",
    "indent_size": "2"
  },
  "diagnostic-languageserver": {
    "formatters": {
      "stylua": {
        "command": "stylua",
        "args": [
          "--color",
          "Never",
          "-"
        ],
        "rootPatterns": [
          "stylua.toml",
          ".stylua.toml"
        ],
      },
    },
    "formatFiletypes": {
      "lua": "stylua",
    },
  },
}
