{
  "coc.preferences.formatOnSave": false,
  "coc.preferences.formatOnType": true,
  "suggest.noselect": true,
  "codeLens.enable": true,
  "diagnostic": {
    "virtualText": true,
    "refreshOnInsertMode": true,
  },
  "git.floatConfig": {
    "border": true
  },
  "diagnostic.floatConfig": {
    "border": true
  },
  "signature.floatConfig": {
    "border": true
  },
  "hover.floatConfig": {
    "border": true
  },
  "sumneko-lua": {
    "serverDir": "/home/tippy/.local/share/sumneko-lua-language-server/share/lua-language-server",
    "enableNvimLuaDev": true,
  },
  "languageserver": {
    "nix": {
      "command": "nil",
      "filetypes": [
        "nix"
      ],
      "rootPatterns": [
        "flake.nix",
        ".git"
      ],
      "settings.nil": {
        "formatting.command": "nixpkgs-fmt",
      },
    },
  },
}
