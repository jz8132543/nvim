{
  "coc.preferences": {
    "formatOnSave": true,
    "formatOnType": true,
    "currentFunctionSymbolAutoUpdate": true,
  },
  "suggest.noselect": true,
  "codeLens.enable": true,
  "diagnostic": {
    "virtualText": true,
    "refreshOnInsertMode": true,
  },
  "git.floatConfig": {
    "border": true
  },
  "diagnostic.floatConfig": {
    "border": true
  },
  "signature.floatConfig": {
    "border": true
  },
  "hover.floatConfig": {
    "border": true
  },
  "languageserver": {
    "nix": {
      "command": "nil",
      "filetypes": [
        "nix"
      ],
      "rootPatterns": [
        ".git"
      ],
      "settings.nil": {
        "formatting.command": "nixpkgs-fmt",
      },
    },
  },
}
